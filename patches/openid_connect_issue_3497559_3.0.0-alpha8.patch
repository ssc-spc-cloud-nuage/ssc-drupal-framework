+      '#description' => $this->t('Enable this if you would like roles to be reset on every login. When this is enabled, upon login, if the groups returned by the provider are empty and any role mappings are defined, then all Drupal roles will be cleared. This was the default behavior up until to 3.x-beta6.'),
+    ];
+
     $form['advanced'] = [
       '#title' => $this->t('Advanced'),
       '#type' => 'details',
@@ -248,7 +255,6 @@ class OpenIDConnectSettingsForm extends ConfigFormBase {
    */
